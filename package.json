{
  "name": "booking-platform-aws",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "imports": {
    "#domain/*": "./src/domain/*.ts",
    "#application/*": "./src/application/*.ts",
    "#infrastructure/*": "./src/infrastructure/*.ts",
    "#interfaces/*": "./src/interfaces/*.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "dev:docker": "tsx watch src/main.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/main.js",
    "lint": "eslint .",
    "test": "vitest",
    "migrate": "prisma migrate deploy",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "deps:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot | dot -T svg > deps.svg",
    "deps:archi": "depcruise src --config .dependency-cruiser.cjs --output-type archi | dot -T svg > deps-archi.svg"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  }
}
